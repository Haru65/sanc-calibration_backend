DATABASE_URL="postgresql://user:password@localhost:5432/sanc_calibration"
JWT_SECRET="your-secret-key-here"
JWT_EXPIRE="7d"
NODE_ENV="development"
PORT=5000
CORS_ORIGIN="http://localhost:5173"
ERPNEXT_BASE_URL="https://aits-sancpl.m.frappe.cloud/api"
ERPNEXT_API_KEY="your-erpnext-api-key"
ERPNEXT_API_SECRET="your-erpnext-api-secret"
ERPNEXT_AUTH_SCHEME="basic"
